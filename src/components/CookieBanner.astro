---
// LGPD cookie consent banner
---

<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-50 bg-card border-t border-line px-6 py-4 hidden"
  style="padding-bottom: max(1rem, env(safe-area-inset-bottom));"
  role="dialog"
  aria-label="Aviso de Cookies"
  aria-live="polite"
>
  <div class="w-full mx-auto max-w-7xl flex flex-col sm:flex-row items-start sm:items-center gap-4">
    <p class="text-muted text-sm flex-1 leading-relaxed">
      Utilizamos cookies para melhorar sua experiência. Ao continuar navegando, você concorda com nossa{' '}
      <a href="/politica-de-privacidade" class="text-gold underline hover:text-gold-light transition-colors">
        Política de Privacidade
      </a>
      {' '}em conformidade com a LGPD.
    </p>
    <div class="flex items-center gap-3 shrink-0 w-full sm:w-auto">
      <button
        id="cookie-reject"
        class="flex-1 sm:flex-none text-muted text-sm hover:text-cream transition-colors px-4 py-3 border border-line rounded hover:border-muted min-h-[44px]"
      >
        Rejeitar
      </button>
      <button
        id="cookie-accept"
        class="flex-1 sm:flex-none bg-gold hover:bg-gold-light text-dark text-sm font-semibold px-5 py-3 rounded transition-colors min-h-[44px]"
      >
        Aceitar
      </button>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner')!;
  const accept = document.getElementById('cookie-accept')!;
  const reject = document.getElementById('cookie-reject')!;

  const COOKIE_KEY = 'cookie_consent';

  if (!localStorage.getItem(COOKIE_KEY)) {
    setTimeout(() => banner.classList.remove('hidden'), 1500);
  }

  accept.addEventListener('click', () => {
    localStorage.setItem(COOKIE_KEY, 'accepted');
    banner.classList.add('hidden');
  });

  reject.addEventListener('click', () => {
    localStorage.setItem(COOKIE_KEY, 'rejected');
    banner.classList.add('hidden');
  });
</script>
