---
import { siteConfig } from '../config';
const waMensagem = encodeURIComponent(siteConfig.whatsappMensagem);

const etapas = [
  {
    numero: '01',
    titulo: 'Consulta Confidencial',
    descricao:
      'Entre em contato por WhatsApp ou formulário. Analisamos seu caso com total sigilo e sem compromisso. Atendemos 24 horas, 7 dias por semana.',
    icone: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
  },
  {
    numero: '02',
    titulo: 'Estratégia de Defesa',
    descricao:
      'Após análise completa do caso, elaboramos a estratégia jurídica mais adequada, com clareza sobre os caminhos possíveis e os melhores resultados esperados.',
    icone: `<path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>`,
  },
  {
    numero: '03',
    titulo: 'Defesa Firme e Atuante',
    descricao:
      'Atuação presencial em todas as etapas do processo: audiências, manifestações, recursos e acompanhamento contínuo até a resolução definitiva do caso.',
    icone: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  },
];
---

<section class="py-10 sm:py-20 lg:py-32 bg-dark relative overflow-hidden" aria-labelledby="como-funciona-titulo">
  <!-- Linha decorativa diagonal -->
  <div class="absolute right-0 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-line to-transparent" aria-hidden="true"></div>

  <div class="w-full mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
    <!-- Cabeçalho -->
    <div class="max-w-2xl mb-7 sm:mb-16 lg:mb-20">
      <p class="text-gold text-xs tracking-[0.25em] uppercase mb-4 font-medium">Processo simplificado</p>
      <h2
        id="como-funciona-titulo"
        class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-cream leading-tight"
      >
        Como funciona nossa defesa
      </h2>
    </div>

    <!-- Etapas -->
    <div class="grid lg:grid-cols-3 gap-6 lg:gap-0 relative">
      <!-- Linha conectora desktop -->
      <div class="hidden lg:block absolute top-10 left-[16.67%] right-[16.67%] h-px bg-line" aria-hidden="true"></div>

      {etapas.map((etapa, i) => (
        <div class={`relative ${i > 0 ? 'lg:pl-10' : ''}`}>
          <!-- Número e ícone -->
          <div class="relative flex items-center gap-4 mb-4 sm:mb-6">
            <div class="flex-shrink-0 w-12 h-12 sm:w-16 sm:h-16 rounded-full border border-line bg-card flex flex-col items-center justify-center relative z-10">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="#c9a84c"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={etapa.icone}
              />
            </div>
            <span class="font-display text-3xl sm:text-5xl font-bold text-line">{etapa.numero}</span>
          </div>

          <!-- Conteúdo -->
          <h3 class="font-display text-xl font-bold text-cream mb-3">{etapa.titulo}</h3>
          <p class="text-muted text-sm leading-relaxed line-clamp-3 sm:line-clamp-none">{etapa.descricao}</p>
        </div>
      ))}
    </div>

    <!-- CTA no final da seção -->
    <div class="mt-10 lg:mt-20 flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-6 border-t border-line pt-8">
      <p class="hidden sm:block text-muted flex-1 text-sm lg:text-base">
        Pronto para dar o primeiro passo? A consulta inicial é <strong class="text-cream">gratuita e confidencial</strong>.
      </p>
      <a
        href={`https://wa.me/${siteConfig.whatsapp}?text=${waMensagem}`}
        target="_blank"
        rel="noopener noreferrer"
        class="w-full sm:w-auto sm:flex-shrink-0 inline-flex items-center justify-center gap-2 bg-gold hover:bg-gold-light text-dark font-semibold px-7 py-3.5 rounded text-sm transition-colors duration-200"
      >
        Iniciar agora
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
