---
import { siteConfig } from '../config';
const waMensagem = encodeURIComponent(siteConfig.whatsappMensagem);
const temFoto = siteConfig.foto && siteConfig.foto.trim() !== '';
---

<section
  id="inicio"
  class="relative min-h-svh flex flex-col justify-center overflow-hidden"
  aria-label="Apresentação"
>
  <!-- Fundo: gradiente com brilho dourado sutil no topo -->
  <div class="absolute inset-0 -z-10">
    <div
      class="absolute inset-0"
      style="background: radial-gradient(ellipse 80% 50% at 50% -10%, rgba(201,168,76,0.12) 0%, transparent 65%), #0a0a0a;"
    ></div>
    <!-- Linha dourada no topo -->
    <div class="absolute top-0 left-0 right-0 h-[2px] bg-gold opacity-60"></div>
    <!-- Grade sutil de fundo -->
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: linear-gradient(#c9a84c 1px, transparent 1px), linear-gradient(90deg, #c9a84c 1px, transparent 1px); background-size: 60px 60px;"
    ></div>
  </div>

  <div class="w-full mx-auto max-w-7xl px-5 sm:px-6 lg:px-8 pt-20 pb-16 lg:pt-36 lg:pb-28">
    <!-- Grid: texto à esquerda, foto à direita (desktop) -->
    <div class="grid lg:grid-cols-2 lg:gap-16 xl:gap-24 items-center">

      <!-- Conteúdo -->
      <div>
        <!-- Badge -->
        <div class="mb-5 sm:mb-6 inline-flex items-center gap-2 border border-line rounded-full px-3 sm:px-4 py-1.5 max-w-full overflow-hidden">
          <span class="w-1.5 h-1.5 rounded-full bg-gold animate-pulse flex-shrink-0"></span>
          <span class="text-[10px] sm:text-xs text-muted tracking-[0.12em] sm:tracking-widest uppercase truncate">
            <span class="sm:hidden">{siteConfig.oab} &bull; 24h</span>
            <span class="hidden sm:inline">{siteConfig.oab} &mdash; Atendimento 24h</span>
          </span>
        </div>

        <!-- Headline -->
        <h1 class="font-display text-[2rem] sm:text-5xl lg:text-[3.25rem] xl:text-6xl font-bold leading-[1.1] text-cream mb-5 sm:mb-6">
          {siteConfig.headline.split(' ').slice(0, -1).join(' ')}
          <span class="text-gold"> {siteConfig.headline.split(' ').slice(-1)[0]}</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-base sm:text-lg text-muted leading-relaxed mb-8 sm:mb-10 max-w-lg">
          {siteConfig.subheadline}
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
          <a
            href={`https://wa.me/${siteConfig.whatsapp}?text=${waMensagem}`}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2.5 bg-gold hover:bg-gold-light text-dark font-semibold text-sm sm:text-base px-6 sm:px-8 py-4 rounded transition-colors duration-200 min-h-[52px]"
            aria-label="Consulta gratuita via WhatsApp"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="flex-shrink-0">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.025.504 3.935 1.388 5.608L0 24l6.608-1.372A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 0 1-5.013-1.374l-.36-.214-3.724.773.793-3.618-.234-.372A9.818 9.818 0 1 1 12 21.818z"/>
            </svg>
            Consulta Gratuita
          </a>
          <a
            href="#servicos"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 border border-line hover:border-gold text-cream text-sm sm:text-base font-medium px-6 sm:px-8 py-4 rounded transition-colors duration-200 min-h-[52px]"
          >
            Conheça nosso trabalho
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Foto do advogado — banner full-width no mobile, retrato à direita no desktop -->
      <div class="order-first lg:order-last flex justify-center lg:justify-end lg:pr-8 mb-6 lg:mb-0">
        <div class="relative w-full lg:max-w-[340px]">
          <!-- Quadro decorativo (só desktop) -->
          <div
            class="hidden lg:block absolute inset-0 border border-gold/25 rounded translate-x-4 translate-y-4"
            aria-hidden="true"
          ></div>

          {temFoto && (
            <img
              src={siteConfig.foto}
              alt={`${siteConfig.nomeCompleto} — ${siteConfig.especialidade}`}
              width="340"
              height="453"
              loading="eager"
              fetchpriority="high"
              class="relative z-10 w-full h-[320px] sm:h-[360px] lg:h-auto lg:aspect-[3/4] object-cover object-[center_20%] rounded"
            />
          )}
          {!temFoto && (
            <div
              class="relative z-10 w-full h-[280px] sm:h-[340px] lg:h-auto lg:aspect-[3/4] bg-card border border-line rounded flex flex-col items-center justify-center gap-3"
              aria-label="Placeholder para foto do advogado"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#2a2a2a" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
              <p class="text-xs text-line text-center px-6 leading-relaxed">
                Foto profissional do advogado<br/>(proporção 3:4)
              </p>
            </div>
          )}

          <!-- Overlay gradiente na base da foto -->
          <div
            class="absolute bottom-0 left-0 right-0 h-1/3 z-20 rounded-b"
            style="background: linear-gradient(to top, rgba(10,10,10,0.5) 0%, transparent 100%);"
            aria-hidden="true"
          ></div>

          <!-- Badge OAB (só desktop) -->
          <div class="hidden lg:block absolute bottom-5 left-5 z-30 bg-gold text-dark rounded px-4 py-2 shadow-xl">
            <p class="text-[9px] font-bold uppercase tracking-widest leading-none mb-0.5">Inscrito</p>
            <p class="font-display text-xs font-bold leading-tight">{siteConfig.oab}</p>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Indicador de scroll -->
  <div class="absolute bottom-6 sm:bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-muted" aria-hidden="true">
    <span class="text-[10px] tracking-widest uppercase hidden sm:block">Role para baixo</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="animate-bounce">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </div>
</section>
