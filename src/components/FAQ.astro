---
import { siteConfig } from '../config';

// Schema JSON-LD para FAQ
const jsonLdFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: siteConfig.faq.map((item) => ({
    '@type': 'Question',
    name: item.pergunta,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.resposta,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLdFaq)} />

<section id="faq" class="py-16 sm:py-20 lg:py-32 bg-dark" aria-labelledby="faq-titulo">
  <div class="w-full mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-[1fr_2fr] gap-6 lg:gap-20">
      <!-- Cabeçalho colateral -->
      <div class="lg:sticky lg:top-28 lg:self-start">
        <p class="text-gold text-xs tracking-[0.25em] uppercase mb-4 font-medium">Perguntas frequentes</p>
        <h2
          id="faq-titulo"
          class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-cream leading-tight mb-6"
        >
          Dúvidas comuns sobre Direito Criminal
        </h2>
        <p class="hidden sm:block text-muted text-sm leading-relaxed">
          Não encontrou o que procura? Entre em contato diretamente.
        </p>
        <a
          href="#contato"
          class="hidden sm:inline-flex mt-6 items-center gap-2 text-gold text-sm hover:text-gold-light transition-colors"
        >
          Enviar sua dúvida
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Accordion CSS-only com details/summary -->
      <div class="space-y-0 divide-y divide-line border-y border-line">
        {siteConfig.faq.map((item, i) => (
          <details class={`group${i >= 3 ? ' hidden sm:block' : ''}`}>
            <summary class="flex items-center justify-between gap-4 py-6 cursor-pointer list-none">
              <span class="font-medium text-cream text-base group-open:text-gold transition-colors duration-200">
                {item.pergunta}
              </span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="faq-icon shrink-0 text-muted group-open:text-gold transition-all duration-300"
                aria-hidden="true"
              >
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </summary>
            <div class="faq-body pb-6">
              <p class="text-muted text-sm leading-relaxed">{item.resposta}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>
