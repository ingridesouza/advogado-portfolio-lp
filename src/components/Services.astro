---
import { siteConfig } from '../config';

// Ícones SVG por tipo (stroke only, tamanho 24x24)
const icons: Record<string, string> = {
  shield: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  gavel: `<path d="m14 13-8.5 8.5a2.121 2.121 0 0 1-3-3L11 10"/><path d="m16 16 6-6"/><path d="m8 8 6-6"/><line x1="20" x2="13" y1="13" y2="20"/><line x1="4" x2="11" y1="4" y2="11"/>`,
  clock: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  scale: `<line x1="12" y1="3" x2="12" y2="21"/><path d="M3 9h9"/><path d="M12 9h9"/><path d="M6 3 3 9l3 6"/><path d="m18 3 3 6-3 6"/>`,
  document: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>`,
  search: `<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>`,
};
---

<section id="servicos" class="py-16 sm:py-20 lg:py-32 bg-dark" aria-labelledby="servicos-titulo">
  <div class="w-full mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
    <!-- Cabeçalho da seção -->
    <div class="max-w-2xl mb-7 sm:mb-16 lg:mb-20">
      <p class="text-gold text-xs tracking-[0.25em] uppercase mb-4 font-medium">Áreas de atuação</p>
      <h2
        id="servicos-titulo"
        class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-cream leading-tight mb-4"
      >
        Defesa especializada em cada etapa
      </h2>
      <p class="hidden sm:block text-muted text-lg leading-relaxed">
        Atuação técnica e estratégica em todas as esferas do Direito Criminal, garantindo a melhor defesa em cada fase do processo.
      </p>
    </div>

    <!-- Grid de serviços -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-line">
      {siteConfig.servicos.map((servico) => (
        <article class="bg-dark p-4 sm:p-8 lg:p-10 group hover:bg-card transition-colors duration-300">
          <!-- Ícone -->
          <div class="mb-4 sm:mb-6 w-12 h-12 flex items-center justify-center border border-line group-hover:border-gold rounded transition-colors duration-300">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#c9a84c"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={icons[servico.icone] ?? icons.shield}
            />
          </div>

          <!-- Conteúdo -->
          <h3 class="font-display text-xl font-bold text-cream mb-3 group-hover:text-gold transition-colors duration-300">
            {servico.titulo}
          </h3>
          <p class="text-muted text-sm leading-relaxed line-clamp-3 sm:line-clamp-none">
            {servico.descricao}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
